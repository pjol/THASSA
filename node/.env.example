PORT=8080
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_CONTEXT_CHARS=16000
# Full onchain model commitment string (hashed by hub checks).
# The server derives runtime OpenAI model id from "openai:<id>" unless overridden per request.
OPENAI_MODEL=openai:gpt-5.4-mini
NODE_PRIVATE_KEY=<hex-private-key-without-0x-or-with-0x>
THASSA_RPC_URL=<chain-rpc-url>

# Enable background bid scanning + auto submitAutoUpdate flow.
AUTO_FULFILL_BIDS=true
BID_SCAN_INTERVAL_SECONDS=2
AUTO_FULFILL_LLM_TIMEOUT_SECONDS=120

# ABI path used by auto-fulfill worker.
ABI_DIR=abi

# JSON object passed as inputData to structured-output calls for auto fulfillment.
# Optional extra context only (the worker always reads query/shape/model from oracle contract).
# Example: {"asset":"SPY","source":"demo"}
AUTO_FULFILL_INPUT_DATA_JSON={}

# Optional defaults used when omitted in request body.
DEFAULT_THASSA_HUB=<optional-default-hub-address>
DEFAULT_CHAIN_ID=31337
DEFAULT_CLIENT_VERSION=1
DEFAULT_TTL_SECONDS=3600
REQUEST_TIMEOUT_SECONDS=45

# Backend MCP endpoint used to refresh the settlement resolution-source registry (spec 6.5b).
# Empty = use the node's built-in default registry (ESPN / news majority panel / NWS / Coinbase).
NODE_MCP_URL=
# Timeout for per-source HTTP fetches during settlement adjudication.
SOURCE_FETCH_TIMEOUT_SECONDS=10
