# Thassa mobile environment. All values are compiled into the client bundle
# (EXPO_PUBLIC_*), so never put secrets here.

# Backend REST base URL (spec 6.3). On a physical device use your LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:8080

# WebSocket base URL (spec 6.4). Defaults to EXPO_PUBLIC_API_URL with ws scheme.
EXPO_PUBLIC_WS_URL=ws://localhost:8080

# Privy app id (embedded wallets + auth).
EXPO_PUBLIC_PRIVY_APP_ID=your-privy-app-id
# Optional Privy mobile client id (recommended by Privy for Expo apps).
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# Chain params (spec 3, 9). Dev: local anvil (31337).
EXPO_PUBLIC_CHAIN_ID=31337
EXPO_PUBLIC_MARKETS_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
EXPO_PUBLIC_PAYMENT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# Payment token decimals (code assumes 6 unless overridden by /v1/wallet).
EXPO_PUBLIC_PAYMENT_TOKEN_DECIMALS=6
