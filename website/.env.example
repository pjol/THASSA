# Thassa website — public build-time configuration.
# All values are baked into the static export at build time.

# Web app (the "Open the app" CTA + QR code target)
NEXT_PUBLIC_APP_URL=https://app.thassa.xyz

# Trading / platform API base URL used throughout the docs examples.
# Dev backend runs on localhost:8080.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Store listings. Leave unset to show the "coming soon" state on /download.
NEXT_PUBLIC_APPSTORE_URL=
NEXT_PUBLIC_PLAYSTORE_URL=
