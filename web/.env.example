# Thassa web — copy to .env.local and fill in.

# Backend API (spec §6.3). Named-key envelopes with next_cursor.
NEXT_PUBLIC_API_URL=http://localhost:8080
# WebSocket endpoint (spec §6.4). Defaults to API host + /v1/ws if unset.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/v1/ws

# Developer docs site (linked from Settings → Developer).
NEXT_PUBLIC_DOCS_URL=http://localhost:3001/docs

# Privy (embedded wallets). Swap AuthProvider for Signet later.
NEXT_PUBLIC_PRIVY_APP_ID=

# Chain (Tempo; anvil in dev) — used for EIP-712 / EIP-3009 domains.
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_MARKETS_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PAYMENT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# EIP-712 domain of the payment token for EIP-3009 auths (MockUSD in dev).
NEXT_PUBLIC_PAYMENT_TOKEN_NAME=MockUSD
NEXT_PUBLIC_PAYMENT_TOKEN_VERSION=1
NEXT_PUBLIC_PAYMENT_TOKEN_DECIMALS=6
