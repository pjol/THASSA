# --- Server ---
PORT=8080
ENV=development
# Serving region, reported by /health (spec §6.7 region-based deployment).
REGION=local
# Comma-separated allowed CORS origins (web + expo dev).
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,exp://127.0.0.1:19000
# This instance's externally-reachable base URL (dev local-upload URLs).
PUBLIC_API_URL=http://localhost:8080
# Web app URL (onramp redirects).
PUBLIC_WEB_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://thassa:thassa@localhost:5432/thassa?sslmode=disable

# --- Realtime bus (spec §6.7) ---
# pg    = Postgres LISTEN/NOTIFY (default, zero extra infra)
# redis = Redis pub/sub (go-redis), for larger fleets
BUS_DRIVER=pg
REDIS_URL=redis://localhost:6379/0

# --- Privy auth ---
# The backend verifies Privy access tokens (ES256) against
PRIVY_APP_ID=your-privy-app-id
# App verification key (PEM, Privy dashboard → Settings → Verification key).
# Set ⇒ tokens verify fully locally with the pinned key (no network callout —
# use this in production). Unset ⇒ dev fallback fetches the app JWKS from
# https://auth.privy.io/api/v1/apps/{PRIVY_APP_ID}/jwks.json (cached).
# Literal \n escapes are accepted so the PEM can sit on one line.
PRIVY_VERIFICATION_KEY=

# --- S3 / object storage ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=thassa-assets
S3_ACCESS_KEY=thassa
S3_SECRET_KEY=thassa-secret
# Public base URL used to render stored assets (CDN or bucket URL).
S3_PUBLIC_URL=http://localhost:9000/thassa-assets
# Set true for MinIO / path-style buckets.
S3_FORCE_PATH_STYLE=true

# --- Storage mode ---
# false (default): store uploads on the local filesystem (LOCAL_UPLOAD_DIR),
#   served by this server at /uploads/* — no S3/MinIO needed for development.
# true: use the S3_* bucket settings above.
IN_PRODUCTION=false
LOCAL_UPLOAD_DIR=uploads

# --- LLM market-generation agent (spec §6.5) ---
OPENAI_API_KEY=
LLM_MODEL=gpt-5.4

# --- MCP (spec §6.5b) ---
# Bearer token remote oracle nodes use against POST /v1/mcp (tools/list,
# tools/call: search_markets, list_sources, resolve_sources). Empty disables
# remote node access (the in-process generation agent still works).
MCP_NODE_TOKEN=

# --- Chain (spec §3/§6.6) ---
CHAIN_RPC_URL=http://localhost:8545
CHAIN_ID=31337
# The single payment stablecoin (ERC-20 + EIP-3009; MockUSD in dev).
PAYMENT_TOKEN_ADDRESS=
# ThassaMarkets (all markets live in one contract).
MARKETS_CONTRACT_ADDRESS=
# Thassa hub (oracle).
HUB_ADDRESS=
# Funded key the relayer signs with (an anvil key in dev). Chain services
# (relayer/indexer/settlement) stay disabled until token+markets+key are set.
RELAYER_PRIVATE_KEY=
# Batch cadence / size for placeOrdersBatch.
RELAYER_BATCH_MS=2000
RELAYER_BATCH_MAX=25
# Relayer gas-sponsorship limits: max single-order cost (token base units,
# default $1000 at 6 decimals) and per-user relayed orders per minute.
MAX_ORDER_COST=1000000000
ORDER_RATE_PER_MIN=30

# --- Onramp ---
# Fiat rail: Stripe Checkout. Endpoints return an explicit configuration
# error when unset (no mock data).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Crypto rail: LI.FI-style bridge aggregator for cross-chain quotes; direct
# home-chain deposits (watched by the indexer) need no credential.
BRIDGE_API_URL=https://li.quest
BRIDGE_API_KEY=
# Where hosted checkout redirects back to.
ONRAMP_RETURN_URL=http://localhost:3000/wallet
