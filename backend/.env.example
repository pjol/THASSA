# --- Server ---
PORT=8080
ENV=development
# Serving region, reported by /health (spec §6.7 region-based deployment).
REGION=local
# Comma-separated allowed CORS origins (web + expo dev).
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,exp://127.0.0.1:19000
# This instance's externally-reachable base URL (dev local-upload URLs).
PUBLIC_API_URL=http://localhost:8080
# Web app URL (onramp redirects).
PUBLIC_WEB_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://thassa:thassa@localhost:5432/thassa?sslmode=disable

# --- Push notifications (spec §7d.4) ---
# Expo push delivery is built-in and needs NO configuration or API key: the
# backend POSTs to https://exp.host/--/api/v2/push/send using device tokens
# registered via POST /v1/me/push-token. Delivery is best-effort and
# non-blocking; invalid tokens (DeviceNotRegistered) are pruned automatically.

# --- Realtime bus (spec §6.7) ---
# pg    = Postgres LISTEN/NOTIFY (default, zero extra infra)
# redis = Redis pub/sub (go-redis), for larger fleets
BUS_DRIVER=pg
REDIS_URL=redis://localhost:6379/0

# --- Privy auth ---
# The backend verifies Privy access tokens (ES256) against
PRIVY_APP_ID=your-privy-app-id
# App VERIFICATION KEY — the PUBLIC key used to verify access-token JWT
# signatures locally. This is NOT the Privy app secret. Copy the PEM from the
# Privy dashboard → your app → Settings → "Verification key"
# (-----BEGIN PUBLIC KEY----- … -----END PUBLIC KEY-----). A single-line PEM,
# a PEM with literal \n escapes, or the bare base64 body are all accepted.
# Set ⇒ tokens verify fully locally (no network callout — use in production).
# Unset ⇒ dev fallback fetches the app JWKS from auth.privy.io (cached).
#
PRIVY_VERIFICATION_KEY=
# App SECRET (optional) — enables the Privy server API (auth.privy.io) so a
# user's VERIFIED email can be resolved by DID when it is not carried in the
# access token. This is the ONLY thing the app secret is used for here (token
# verification still uses the public key above). In production this is what
# enables verified admin-email matching. Leave empty in dev.
PRIVY_APP_SECRET=

# --- Admin & warp (spec §7c) ---
# Comma-separated admin emails (case-insensitive). A user is an admin when
# their email is VERIFIED and matches this set — a spoofed client email can
# never grant admin. Admins can "warp" (impersonate, read-only) any user.
ADMIN_EMAILS=
# Verified email requires PRIVY_APP_SECRET (production) or an email claim in
# the token. For LOCAL DEV ONLY, set this true to let an UNVERIFIED email
# satisfy admin matching when no app secret is configured. INSECURE — never
# enable in production.
ADMIN_TRUST_UNVERIFIED_EMAIL=false

# --- S3 / object storage ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=thassa-assets
S3_ACCESS_KEY=thassa
S3_SECRET_KEY=thassa-secret
# Public base URL used to render stored assets (CDN or bucket URL).
S3_PUBLIC_URL=http://localhost:9000/thassa-assets
# Set true for MinIO / path-style buckets.
S3_FORCE_PATH_STYLE=true

# --- Storage mode ---
# false (default): store uploads on the local filesystem (LOCAL_UPLOAD_DIR),
#   served by this server at /uploads/* — no S3/MinIO needed for development.
# true: use the S3_* bucket settings above.
IN_PRODUCTION=false
LOCAL_UPLOAD_DIR=uploads

# --- LLM market-generation agent (spec §6.5) ---
OPENAI_API_KEY=
LLM_MODEL=gpt-5.4

# --- MCP (spec §6.5b) ---
# Bearer token remote oracle nodes use against POST /v1/mcp (tools/list,
# tools/call: search_markets, list_sources, resolve_sources). Empty disables
# remote node access (the in-process generation agent still works).
MCP_NODE_TOKEN=

# --- Chain (spec §3/§6.6) ---
CHAIN_RPC_URL=http://localhost:8545
CHAIN_ID=31337
# The single payment stablecoin (ERC-20 + EIP-3009; MockUSD in dev).
PAYMENT_TOKEN_ADDRESS=
# ThassaMarkets (all markets live in one contract).
MARKETS_CONTRACT_ADDRESS=
# Thassa hub (oracle).
HUB_ADDRESS=
# Funded key the relayer signs with (an anvil key in dev). Chain services
# (relayer/indexer/settlement) stay disabled until token+markets+key are set.
RELAYER_PRIVATE_KEY=
# Batch cadence / size for placeOrdersBatch.
RELAYER_BATCH_MS=2000
RELAYER_BATCH_MAX=25
# Relayer gas-sponsorship limits: max single-order cost (token base units,
# default $1000 at 6 decimals) and per-user relayed orders per minute.
MAX_ORDER_COST=1000000000
ORDER_RATE_PER_MIN=30

# --- Seeder (cmd/seed) ---
# SEED_SKIP_CHAIN=true (default) seeds fake-chain markets only. Set to false to
# deploy the live OPEN/MATCHED demo markets for real on-chain (needs the three
# chain addresses above + funded keys below).
SEED_SKIP_CHAIN=true
# Comma-separated funded dev private keys (anvil accounts) the seeder uses to
# create live markets: their addresses are assigned as the wallet_address of a
# few seed users, they are minted MockUSD, and they sign the opening orders +
# EIP-3009 auths. Empty ⇒ falls back to RELAYER_PRIVATE_KEY (usually too few
# keys for a live market, so markets then stay fake-chain). ~6 keys deploy all
# demo markets; fewer deploy a subset, the rest fall back to fake-chain.
SEED_FUNDED_KEYS=

# --- Onramp ---
# Fiat rail: Stripe Checkout. Endpoints return an explicit configuration
# error when unset (no mock data).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Crypto rail: LI.FI-style bridge aggregator for cross-chain quotes; direct
# home-chain deposits (watched by the indexer) need no credential.
BRIDGE_API_URL=https://li.quest
BRIDGE_API_KEY=
# Where hosted checkout redirects back to.
ONRAMP_RETURN_URL=http://localhost:3000/wallet
