# Thassa boot.sh configuration — copy to .env.boot and adjust (boot.sh will
# auto-create this file from the example if missing).
# boot.sh starts: docker infra (postgres+minio), anvil (optionally forking Tempo),
# contract deployment, funding pranks, backend, oracle node, web, and mobile.
#
# Everything is auto-filled with working dev defaults EXCEPT two values you
# must set by hand for full functionality:
#   PRIVY_APP_ID    — backend requires it at boot; app login needs it
#   OPENAI_API_KEY  — oracle node requires it; market generation uses it
# Optional: PRIVY_CLIENT_ID (mobile), PRIVY_VERIFICATION_KEY (local JWT
# verification; dev falls back to JWKS), STRIPE_* (fiat onramp only).

# ── Chain ────────────────────────────────────────────────────────────────────
# Upstream Tempo RPC to fork with anvil. Leave empty for a plain local anvil chain.
TEMPO_FORK_RPC_URL=
# Local anvil port.
ANVIL_PORT=8545
# Chain id override. Empty = keep the forked chain's id (or anvil's 31337 when not forking).
CHAIN_ID=

# ── Payment token ────────────────────────────────────────────────────────────
# Existing EIP-3009 stablecoin on the fork (e.g. the Tempo payment asset).
# Leave empty to deploy MockUSD locally (open mint faucet).
PAYMENT_TOKEN_ADDRESS=
# EIP-712 domain params of the payment token (used by frontends for EIP-3009 auths).
PAYMENT_TOKEN_NAME=MockUSD
PAYMENT_TOKEN_VERSION=1
PAYMENT_TOKEN_DECIMALS=6
# Funded holder to impersonate for token funding when PAYMENT_TOKEN_ADDRESS is set.
# Ignored for MockUSD (boot mints directly).
PAYMENT_TOKEN_WHALE=

# ── Keys (defaults are the standard anvil dev keys 0-3) ─────────────────────
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
NODE_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
RELAYER_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
DEV_USER_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# Funded keys the seeder uses to deploy example markets ON-CHAIN (so they're
# interactive). These must be DIFFERENT from the relayer/node keys above (which
# the running services use) to avoid nonce races. Defaults = standard anvil dev
# keys 4-9; boot.sh funds their addresses with gas + payment tokens. ~6 keys
# deploy all demo markets; fewer deploy a subset (the rest stay fake-chain).
SEED_FUNDED_KEYS=0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926a,0x8b3a350cf5c34c9194ca85829a2df0ec3153be0318b5e2d3348e872092edffba,0x92db14e403b83dfe3df233f83dfa3a0d7096f21ca9b0d6d6b8d88b2b4ec1564e,0x4bbbf85ce3377467afe5d46f804f221813b2bb87f24d81f60f1fcdbf7cbf4356,0xdbda1821b80551c9d65939329250298aa3472ba22feea921c0cf5d620ea67b97,0x2a871d0798f97d79848a013d4936a73bf4cc922c825d33c1cf7073dff6d409c6

# ── Funding pranks ───────────────────────────────────────────────────────────
# Extra addresses (CSV) to fund with gas + payment tokens on boot, e.g. your
# Privy embedded wallet address(es). Deployer/node/relayer/dev-user are always funded.
FUND_ADDRESSES=
# Gas per funded address, in ether.
FUND_ETH_AMOUNT=100
# Payment tokens per funded address, in whole dollars.
FUND_TOKEN_AMOUNT=10000

# ── Services ─────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
WEB_PORT=3000
# To skip components use flags instead: ./boot.sh --no-mobile --no-web --no-node --no-backend

# ── Secrets passed through to services (fill for full functionality) ────────
OPENAI_API_KEY=
PRIVY_APP_ID=
PRIVY_CLIENT_ID=
# Privy app verification key (PEM; \n escapes ok). Set for fully-local JWT
# verification in the backend; unset = dev JWKS fallback.
PRIVY_VERIFICATION_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
